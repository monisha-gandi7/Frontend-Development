// css


*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f4f4f4;
}

.container{
    width:90%;
    margin:30px auto;
    background:white;
    border:2px solid black;
}

/* Header */

header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-left:20px;
    margin-right:20px;
    padding:20px;
}

.logo{
    width:80px;
    height:80px;
    border:2px solid black;
    display:flex;
    justify-content:center;
    align-items:center;
    overflow:hidden;
}

.logo img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.title{
    flex:1;
    margin-left:20px;
}

.info{
    font-size:20px;
}

/* Navigation */

nav{
    display:flex;
    justify-content:center;
    gap:50px;
    padding:15px;
    border-top:2px solid black;
    border-bottom:2px solid black;
    background:#eee;
}

nav a{
    text-decoration:none;
    color:black;
    font-weight:bold;
}

nav a:hover{
    color:blue;
}

/* Main Content */

.content{
    display:flex;
}

/* Sidebar */

aside{
    width:220px;
    border-right:2px solid black;
    padding:20px;
}

aside ul{
    list-style:none;
    margin-top:20px;
}

aside li{
    padding:10px 0;
}

/* Main */

main{
    flex:1;
    padding:20px;
}

/* Cards */

.cards{
    display:flex;
    flex-wrap:wrap;
    gap:20px;
}

.card{
    width:120px;
    height:100px;
    border:2px solid black;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:20px;
    font-weight:bold;
    border-radius:10px;
    background:#f0f8ff;
    transition:0.3s;
}

.card:hover{
    background:#4CAF50;
    color:white;
    transform:scale(1.05);
}
